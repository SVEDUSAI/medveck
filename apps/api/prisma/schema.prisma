generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  VET
  DENTIST
  NURSE
  VENDOR
  LAB
  DRIVER
  ADMIN
  SUPER_ADMIN
}

enum DoctorType {
  MEDICAL
  VETERINARY
  DENTAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  email     String?  @unique
  password  String?
  name      String
  avatar    String?
  role      Role     @default(PATIENT)
  isVerified Boolean @default(false)
  isActive   Boolean @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Patient profile
  dateOfBirth      DateTime?
  gender           Gender?
  bloodGroup       String?
  allergies        String[]
  emergencyContact String?

  // Doctor profile
  doctorType         DoctorType?
  specialization     String?
  qualification      String?
  experience         Int?
  registrationNumber String?
  consultationFee    Float?
  rating             Float        @default(0)
  reviewCount        Int          @default(0)
  isAvailable        Boolean      @default(true)
  hospital           String?
  bio                String?
  languages          String[]

  // Vendor profile
  shopName      String?
  vendorLicense String?
  isOpen        Boolean @default(false)

  // Lab profile
  labName        String?
  labLicense     String?
  labServices    String[]
  homeCollection Boolean @default(false)

  // Driver profile
  vehicleType   String?
  vehicleNumber String?
  driverLicense String?
  isOnline      Boolean @default(false)
  lat           Float?
  lng           Float?

  // Address
  address   Address?  @relation(fields: [addressId], references: [id])
  addressId String?

  // Relations
  patientConsultations Consultation[]  @relation("PatientConsultations")
  doctorConsultations  Consultation[]  @relation("DoctorConsultations")
  patientBookings      Booking[]       @relation("PatientBookings")
  patientOrders        MedicineOrder[] @relation("PatientOrders")
  vendorOrders         MedicineOrder[] @relation("VendorOrders")
  driverOrders         MedicineOrder[] @relation("DriverOrders")
  patientLabBookings   LabBooking[]    @relation("PatientLabBookings")
  labBookings          LabBooking[]    @relation("LabLabBookings")
  prescriptionsGiven   Prescription[]  @relation("DoctorPrescriptions")
  prescriptionsReceived Prescription[] @relation("PatientPrescriptions")
  healthRecords        HealthRecord[]
  ambulanceRequests    AmbulanceRequest[] @relation("PatientAmbulance")
  ambulanceDriverJobs  AmbulanceRequest[] @relation("DriverAmbulance")
  sentMessages         ChatMessage[]   @relation("SentMessages")
  notifications        Notification[]

  @@index([role])
  @@index([phone])
}

model Address {
  id          String  @id @default(cuid())
  street      String
  city        String
  state       String
  pincode     String
  landmark    String?
  lat         Float?
  lng         Float?
  users       User[]
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─── Consultation ────────────────────────────────────

enum ConsultationStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ConsultationType {
  VIDEO
  AUDIO
  CHAT
}

model Consultation {
  id           String             @id @default(cuid())
  patient      User               @relation("PatientConsultations", fields: [patientId], references: [id])
  patientId    String
  doctor       User               @relation("DoctorConsultations", fields: [doctorId], references: [id])
  doctorId     String
  type         ConsultationType
  status       ConsultationStatus @default(WAITING)
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  notes        String?
  fee          Float
  prescription Prescription?
  messages     ChatMessage[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model ChatMessage {
  id              String        @id @default(cuid())
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
  consultationId  String
  sender          User          @relation("SentMessages", fields: [senderId], references: [id])
  senderId        String
  content         String
  type            String        @default("TEXT")
  createdAt       DateTime      @default(now())

  @@index([consultationId])
}

model Prescription {
  id              String        @id @default(cuid())
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
  consultationId  String        @unique
  doctor          User          @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  doctorId        String
  patient         User          @relation("PatientPrescriptions", fields: [patientId], references: [id])
  patientId       String
  diagnosis       String
  medicines       Json
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([patientId])
}

// ─── Bookings (Home Visit, Nurse, Palliative, etc.) ──

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Booking {
  id          String        @id @default(cuid())
  patient     User          @relation("PatientBookings", fields: [patientId], references: [id])
  patientId   String
  serviceType String
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime
  address     String?
  notes       String?
  fee         Float
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([patientId])
  @@index([serviceType])
}

// ─── Medicine Orders ─────────────────────────────────

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

model MedicineOrder {
  id               String      @id @default(cuid())
  patient          User        @relation("PatientOrders", fields: [patientId], references: [id])
  patientId        String
  vendor           User?       @relation("VendorOrders", fields: [vendorId], references: [id])
  vendorId         String?
  driver           User?       @relation("DriverOrders", fields: [driverId], references: [id])
  driverId         String?
  items            Json
  status           OrderStatus @default(PENDING)
  totalAmount      Float
  deliveryAddress  String
  prescriptionUrl  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([patientId])
  @@index([vendorId])
  @@index([driverId])
  @@index([status])
}

// ─── Lab Bookings ────────────────────────────────────

model LabBooking {
  id             String        @id @default(cuid())
  patient        User          @relation("PatientLabBookings", fields: [patientId], references: [id])
  patientId      String
  lab            User?         @relation("LabLabBookings", fields: [labId], references: [id])
  labId          String?
  tests          Json
  status         BookingStatus @default(PENDING)
  homeCollection Boolean       @default(false)
  scheduledAt    DateTime
  address        String?
  totalAmount    Float
  reportUrl      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([patientId])
  @@index([labId])
}

// ─── Health Records ──────────────────────────────────

model HealthRecord {
  id         String   @id @default(cuid())
  patient    User     @relation(fields: [patientId], references: [id])
  patientId  String
  type       String
  title      String
  fileUrl    String
  doctorName String?
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())

  @@index([patientId])
}

// ─── Ambulance ───────────────────────────────────────

model AmbulanceRequest {
  id             String      @id @default(cuid())
  patient        User        @relation("PatientAmbulance", fields: [patientId], references: [id])
  patientId      String
  driver         User?       @relation("DriverAmbulance", fields: [driverId], references: [id])
  driverId       String?
  pickupLat      Float
  pickupLng      Float
  pickupAddress  String
  hospitalId     String?
  status         OrderStatus @default(PENDING)
  emergencyType  String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status])
}

// ─── Notifications ───────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  type      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

// ─── Medicines catalog ───────────────────────────────

model Medicine {
  id                   String  @id @default(cuid())
  name                 String
  genericName          String
  manufacturer         String
  price                Float
  category             String
  requiresPrescription Boolean @default(false)
  inStock              Boolean @default(true)
  imageUrl             String?
  description          String?

  @@index([category])
}

// ─── Lab Tests catalog ───────────────────────────────

model LabTest {
  id                      String  @id @default(cuid())
  name                    String
  category                String
  price                   Float
  description             String?
  preparationInstructions String?

  @@index([category])
}

// ─── Audit Log ──────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ─── Platform Config ────────────────────────────────

model PlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
